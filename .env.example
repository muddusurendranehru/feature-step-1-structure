# Neon Postgres — copy from Neon dashboard (Connection details). Use pooler URL.
# IMPORTANT: No quotes around the value. One line, no space before or after =.
# Example: DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/DB?sslmode=verify-full
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# Clerk — from Clerk Dashboard → API Keys
# LOCAL (http://localhost:3000): Development tab → pk_test_ / sk_test_ only.
# PRODUCTION (Render / real domain): Production tab → pk_live_ / sk_live_ — set ONLY on the host (e.g. Render env), not for localhost.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
# Production / SSR metadata (use your real URL on Render)
# NEXT_PUBLIC_APP_URL=https://your-app.onrender.com

# ElevenLabs (voice TTS) — from ElevenLabs dashboard (Profile → API Key; Voices for voice ID)
ELEVENLABS_API_KEY=xi_your_key_here
# Optional: voice ID (default used if not set; find in ElevenLabs Voices)
ELEVENLABS_VOICE_ID=your_voice_id_here

# OpenAI (for voice chat replies) — optional; without it, assistant returns a fallback message
OPENAI_API_KEY=sk-...

# Cloudinary (camp photo uploads) — use ONE of the two options below.
# Option A: single URL (from dashboard "Product Environment Credentials"; store in .env.local only)
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Example format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
#
# Option B: separate vars (Cloud Name top left; click "View API Keys" for secret)
# CLOUDINARY_CLOUD_NAME=drhsco04l
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
#
# Optional: expose cloud name to the browser (e.g. for image URLs); not secret.
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=drhsco04l
#
# For client-side unsigned uploads (create preset in Cloudinary Dashboard → Settings → Upload).
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=clinicflow-preset
